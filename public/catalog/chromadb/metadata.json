{
  "id": "chromadb",
  "name": "Chroma",
  "category": "DATABASE",
  "icon": "chroma",
  "description": "Open-source vector database for AI applications and embeddings.",
  "image": "chromadb/chroma:0.5.0",
  "tags": [
    "database",
    "vector",
    "ai",
    "embeddings"
  ],
  "defaultHostPort": 8000,
  "containerPorts": [
    8000
  ],
  "requires": [],
  "requiredEnv": [],
  "optionalEnv": [
    {
      "name": "IS_PERSISTENT",
      "label": "Enable Persistence",
      "defaultValue": "true",
      "required": false
    },
    {
      "name": "ANONYMIZED_TELEMETRY",
      "label": "Allow Anonymized Telemetry",
      "defaultValue": "false",
      "required": false
    }
  ],
  "publicExposure": "optional",
  "persistenceRequired": true,
  "resourceClass": "light",
  "resourceLimits": {
    "memory": "256M",
    "cpus": "0.25"
  },
  "volumes": [
    {
      "containerPath": "/chroma/chroma",
      "label": "Data directory",
      "description": "Vector data storage",
      "required": true,
      "defaultHostPath": "./data/chromadb"
    }
  ],
  "iconSVG": true
}