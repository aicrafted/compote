{
  "name": "Kafka",
  "category": "MESSAGE BROKERS",
  "icon": "apachekafka",
  "description": "Distributed event store and stream-processing platform.",
  "image": "apache/kafka",
  "defaultImageTag": "latest",
  "tagsApi": "https://hub.docker.com/v2/repositories/apache/kafka/tags",
  "defaultHostPort": 9092,
  "containerPorts": [
    9092
  ],
  "requires": [],
  "requiredEnv": [
    {
      "name": "KAFKA_NODE_ID",
      "label": "Node ID",
      "defaultValue": "1"
    },
    {
      "name": "KAFKA_PROCESS_ROLES",
      "label": "Process Roles",
      "defaultValue": "broker,controller"
    },
    {
      "name": "KAFKA_CONTROLLER_QUORUM_VOTERS",
      "label": "Quorum Voters",
      "defaultValue": "1@localhost:9093"
    },
    {
      "name": "KAFKA_LISTENERS",
      "label": "Listeners",
      "defaultValue": "PLAINTEXT://:9092,CONTROLLER://:9093"
    },
    {
      "name": "KAFKA_ADVERTISED_LISTENERS",
      "label": "Advertised Listeners",
      "defaultValue": "PLAINTEXT://localhost:9092"
    },
    {
      "name": "KAFKA_CONTROLLER_LISTENER_NAMES",
      "label": "Controller Listener Names",
      "defaultValue": "CONTROLLER"
    }
  ],
  "volumes": [
    {
      "containerPath": "/var/lib/kafka/data",
      "description": "Kafka data"
    }
  ],
  "iconSVG": true
}