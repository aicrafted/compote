{
  "id": "zitadel",
  "name": "Zitadel",
  "category": "AUTH",
  "icon": "zitadel",
  "description": "Open-source Identity and Access Management with MFA support.",
  "image": "ghcr.io/zitadel/zitadel:latest",
  "tags": [
    "authentication",
    "identity",
    "mfa",
    "oauth",
    "saml"
  ],
  "defaultHostPort": 8080,
  "containerPorts": [
    8080
  ],
  "requires": [],
  "optionalRequires": ["postgres"],
  "requiredEnv": [
    {
      "name": "ZITADEL_MASTERKEY",
      "label": "Master Key",
      "required": true,
      "isSecret": true,
      "description": "Encryption key for secrets"
    }
  ],
  "volumes": [],
  "publicExposure": "optional",
  "persistenceRequired": true,
  "resourceClass": "medium",
  "resourceLimits": {
    "memory": "1G",
    "cpus": "0.5"
  },
  "iconSVG": true
}