{
  "id": "unbound",
  "name": "Unbound",
  "category": "DNS",
  "icon": "unbound",
  "description": "Validating, recursive, and caching DNS resolver.",
  "image": "mvance/unbound:latest",
  "tags": [
    "dns",
    "resolver",
    "privacy"
  ],
  "defaultHostPort": 53,
  "containerPorts": [
    53
  ],
  "requires": [],
  "requiredEnv": [],
