    {
      "containerPath": "/etc/unbound",
      "description": "Unbound config",
      "required": true,
      "defaultHostPath": "./config/unbound"
    }
  ],
  "publicExposure": "optional",
  "persistenceRequired": false,
  "resourceClass": "light",
