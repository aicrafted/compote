    {
      "containerPath": "/etc/envoy",
      "description": "Envoy config",
      "required": true,
      "defaultHostPath": "./config/envoy"
    }
  ],
  "publicExposure": "optional",
  "persistenceRequired": false,
  "resourceClass": "medium",
  "resourceLimits": {
    "memory": "512M",
    "cpus": "0.5"
