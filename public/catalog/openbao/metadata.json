{
  "id": "openbao",
  "name": "OpenBao",
  "category": "SECRETS",
  "icon": "openbao",
  "description": "Open-source secrets and data protection.",
  "image": "openbao/openbao:latest",
  "tags": [
    "secrets",
    "secrets-management",
    "encryption"
  ],
  "defaultHostPort": 8200,
  "containerPorts": [
    8200
  ],
  "requires": [],
  "requiredEnv": [
    {
      "name": "BAO_DEV_ROOT_TOKEN_ID",
      "label": "Root Token",
      "required": true,
      "isSecret": true
    }
  ],
  "volumes": [
    {
      "containerPath": "/openbao/config",
      "description": "OpenBao config",
      "required": true,
      "defaultHostPath": "./data/openbao"
    }
  ],
  "publicExposure": "optional",
  "persistenceRequired": true,
  "resourceClass": "medium",
  "resourceLimits": {
    "memory": "512M",
    "cpus": "0.5"
  },
  "iconSVG": true
}