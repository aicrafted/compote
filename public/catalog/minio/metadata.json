{
  "id": "minio",
  "name": "MinIO",
  "category": "STORAGE",
  "icon": "minio",
  "description": "High-performance S3-compatible object storage.",
  "image": "minio/minio:latest",
  "tags": [
    "s3",
    "object-storage",
    "storage"
  ],
  "defaultHostPort": 9000,
  "containerPorts": [
    9000,
    9001
  ],
  "requires": [],
  "requiredEnv": [
    {
      "name": "MINIO_ROOT_USER",
      "label": "Root User",
      "required": true
    },
    {
      "name": "MINIO_ROOT_PASSWORD",
      "label": "Root Password",
      "required": true,
      "isSecret": true
    }
  ],
  "volumes": [
    {
      "containerPath": "/data",
      "description": "MinIO data",
      "required": true,
      "defaultHostPath": "./data/minio"
    }
  ],
  "publicExposure": "optional",
  "persistenceRequired": true,
  "resourceClass": "medium",
  "resourceLimits": {
    "memory": "1G",
    "cpus": "0.5"
  },
  "iconSVG": true
}