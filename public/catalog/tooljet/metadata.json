{
  "id": "tooljet",
  "name": "ToolJet",
  "category": "AUTOMATION",
  "icon": "tooljet",
  "description": "Open source low-code platform for building business applications.",
  "image": "jettoolkit/tooljet:latest",
  "tags": ["automation", "low-code", "internal-apps"],
  "defaultHostPort": 3000,
  "containerPorts": [3000],
  "requires": ["postgres"],
  "optionalRequires": ["redis"],
  "requiredEnv": [],
  "volumes": [
    {
      "containerPath": "/var/lib/tooljet",
      "description": "ToolJet data",
      "required": true,
      "defaultHostPath": "./data/tooljet"
    }
  ],
  "publicExposure": "optional",
  "persistenceRequired": true,
  "resourceClass": "medium",
  "resourceLimits": { "memory": "1G", "cpus": "0.5" },
  "iconSVG": true
}