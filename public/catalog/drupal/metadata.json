  "category": "CMS",
  "icon": "drupal",
  "description": "Enterprise web content management.",
  "image": "drupal:latest",
  "tags": ["cms", "enterprise", "php"],
  "defaultHostPort": 8080,
  "containerPorts": [80],
  "requires": ["mysql"],
  "optionalRequires": [],
