{
  "name": "Radarr",
  "category": "MEDIA",
  "icon": "radarr",
  "description": "A movie collection manager for Usenet and BitTorrent users.",
  "image": "linuxserver/radarr:latest",
  "defaultHostPort": 7878,
  "containerPorts": [
    7878
  ],
  "requires": [
    "qbittorrent",
    "prowlarr"
  ],
  "requiredEnv": [],
  "volumes": [
    {
      "containerPath": "/config",
      "description": "Configuration data"
    },
    {
      "containerPath": "/movies",
      "description": "Movies library"
    },
    {
      "containerPath": "/downloads",
      "description": "Downloads source"
    }
  ],
  "publicExposure": "recommended",
  "iconSVG": true
}