{
  "id": "wikijs",
  "name": "Wiki.js",
  "category": "KNOWLEDGE",
  "icon": "wikijs",
  "description": "Modern, lightweight and powerful wiki app.",
  "image": "ghcr.io/requarks/wiki:2",
  "tags": [
    "wiki",
    "knowledge-base",
    "documentation"
  ],
  "defaultHostPort": 8080,
  "containerPorts": [
    3000
  ],
  "requires": [],
  "optionalRequires": ["postgres"],
  "requiredEnv": [],
