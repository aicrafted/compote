    {
      "containerPath": "/wiki/data",
      "description": "Wiki.js data",
      "required": true,
      "defaultHostPath": "./data/wikijs"
    }
  ],
  "publicExposure": "optional",
  "persistenceRequired": true,
  "resourceClass": "medium",
  "resourceLimits": {
    "memory": "1G",
    "cpus": "0.5"
  }
}